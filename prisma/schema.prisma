generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  ARCHIVED
  EXPORTING
}

enum SceneStatus {
  DRAFT
  QUEUED
  GENERATING
  READY
  FAILED
  STALE
  EXPORTING
}

enum AssetType {
  IMAGE
  VIDEO
  FRAME
  THUMBNAIL
  EXPORT
}

enum AssetSource {
  UPLOAD
  FAL_GENERATION
  FRAME_EXTRACT
  EXPORT
}

enum AssetOrigin {
  R2
  EXTERNAL_URL
  PENDING
}

enum JobStatus {
  QUEUED
  GENERATING
  PROCESSING
  READY
  FAILED
  CANCELED
}

enum JobType {
  VIDEO_GENERATION
  IMAGE_GENERATION
  FRAME_EXTRACT
  EXPORT
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELED
}

enum SceneBranchKind {
  AI_CREATOR
  MANUAL_CONTINUE
}

enum SceneBranchStatus {
  GENERATING
  READY
  FAILED
}

model User {
  id               String          @id @default(cuid())
  email            String          @unique
  name             String?
  passwordHash     String?
  avatarUrl        String?
  role             UserRole        @default(USER)
  creditBalance    Int             @default(0)
  storageBytesUsed BigInt          @default(0)
  projectCount     Int             @default(0)
  lastActiveAt     DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  projects         Project[]
  assets           Asset[]
  jobs             GenerationJob[]
  ledgerEntries    CreditLedger[]
  payments         Payment[]
  exportJobs       ExportJob[]
}

model Project {
  id                   String          @id @default(cuid())
  userId               String
  title                String
  aspectRatio          String
  status               ProjectStatus   @default(DRAFT)
  initialFrameAssetId  String?
  coverAssetId         String?
  totalDurationSeconds Int             @default(0)
  sceneCount           Int             @default(0)
  readySceneCount      Int             @default(0)
  timelineItemCount    Int             @default(0)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  archivedAt           DateTime?
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scenes               Scene[]
  assets               Asset[]
  jobs                 GenerationJob[]
  exports              ExportJob[]
  timelineItems        TimelineItem[]
  branches             SceneBranch[]
  initialFrameAsset    Asset?          @relation("ProjectInitialFrame", fields: [initialFrameAssetId], references: [id], onDelete: SetNull)
  coverAsset           Asset?          @relation("ProjectCover", fields: [coverAssetId], references: [id], onDelete: SetNull)

  @@index([userId, archivedAt, updatedAt])
  @@index([coverAssetId])
  @@index([initialFrameAssetId])
}

model SceneBranch {
  id          String            @id @default(cuid())
  projectId   String
  kind        SceneBranchKind
  status      SceneBranchStatus @default(GENERATING)
  totalScenes Int               @default(0)
  readyScenes Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scenes      Scene[]

  @@index([projectId, status])
}

model Scene {
  id                String          @id @default(cuid())
  projectId         String
  branchEntityId    String?
  orderIndex        Int
  durationSeconds   Int             @default(6)
  status            SceneStatus     @default(DRAFT)
  startFrameAssetId String?
  videoAssetId      String?
  endFrameAssetId   String?
  userPrompt        String
  modelId           String
  generationJobId   String?
  parentSceneId     String?
  isStale           Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  project           Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  branch            SceneBranch?    @relation(fields: [branchEntityId], references: [id], onDelete: SetNull)
  startFrameAsset   Asset?          @relation("SceneStartFrame", fields: [startFrameAssetId], references: [id], onDelete: SetNull)
  videoAsset        Asset?          @relation("SceneVideo", fields: [videoAssetId], references: [id], onDelete: SetNull)
  endFrameAsset     Asset?          @relation("SceneEndFrame", fields: [endFrameAssetId], references: [id], onDelete: SetNull)
  parentScene       Scene?          @relation("SceneParent", fields: [parentSceneId], references: [id], onDelete: SetNull)
  childScenes       Scene[]         @relation("SceneParent")
  jobs              GenerationJob[]
  timelineItems     TimelineItem[]

  @@index([projectId, orderIndex])
  @@index([projectId, status])
  @@index([branchEntityId, orderIndex])
  @@index([startFrameAssetId])
  @@index([videoAssetId])
  @@index([endFrameAssetId])
  @@index([parentSceneId])
}

model TimelineItem {
  id               String   @id @default(cuid())
  projectId        String
  sceneId          String
  orderIndex       Int
  trimStartSeconds Int      @default(0)
  trimEndSeconds   Int?
  durationSeconds  Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene            Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([projectId, orderIndex])
  @@index([projectId, sceneId])
}

model Asset {
  id              String      @id @default(cuid())
  userId          String
  projectId       String?
  type            AssetType
  source          AssetSource
  origin          AssetOrigin @default(PENDING)
  r2Key           String?
  externalUrl     String?
  cdnUrl          String?
  signedUrlCache  Json?
  mimeType        String
  sizeBytes       Int?
  width           Int?
  height          Int?
  durationSeconds Int?
  metadataJson    Json?
  createdAt       DateTime    @default(now())
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  initialProjects Project[]   @relation("ProjectInitialFrame")
  coveredProjects Project[]   @relation("ProjectCover")
  startScenes     Scene[]     @relation("SceneStartFrame")
  videoScenes     Scene[]     @relation("SceneVideo")
  endScenes       Scene[]     @relation("SceneEndFrame")

  @@index([userId, projectId, type])
  @@index([projectId, type, createdAt])
  @@index([origin, r2Key])
}

model GenerationJob {
  id                   String         @id @default(cuid())
  userId               String
  projectId            String?
  sceneId              String?
  provider             String
  modelId              String
  providerRequestId    String?
  type                 JobType
  status               JobStatus      @default(QUEUED)
  input                Json
  estimatedCredits     Int            @default(0)
  actualCredits        Int?
  durationMs           Int?
  creditsReserved      Int            @default(0)
  creditsSpent         Int            @default(0)
  providerCostEstimate Float?
  startedAt            DateTime?
  completedAt          DateTime?
  createdAt            DateTime       @default(now())
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project              Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scene                Scene?         @relation(fields: [sceneId], references: [id], onDelete: SetNull)
  ledger               CreditLedger[]
  result               JobResult?
  error                JobError?

  @@index([providerRequestId])
  @@index([userId, status])
  @@index([userId, type, status])
  @@index([status, createdAt])
}

model JobResult {
  jobId       String        @id
  assets      Json          @default("[]")
  rawResponse Json
  createdAt   DateTime      @default(now())
  job         GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model JobError {
  jobId     String        @id
  code      String?
  message   String
  rawError  Json?
  createdAt DateTime      @default(now())
  job       GenerationJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

model CreditLedger {
  id              String         @id @default(cuid())
  userId          String
  amount          Int
  type            String
  reason          String
  generationJobId String?
  stripeEventId   String?
  createdAt       DateTime       @default(now())
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             GenerationJob? @relation(fields: [generationJobId], references: [id])

  @@index([userId, createdAt])
  @@index([userId, type, createdAt])
}

model Payment {
  id                      String        @id @default(cuid())
  userId                  String
  packageKey              String
  amountCents             Int
  currency                String        @default("usd")
  credits                 Int
  status                  PaymentStatus @default(PENDING)
  stripeCheckoutSessionId String?       @unique
  stripePaymentIntentId   String?
  createdAt               DateTime      @default(now())
  paidAt                  DateTime?
  user                    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status])
  @@index([stripePaymentIntentId])
}

model ExportJob {
  id              String    @id @default(cuid())
  projectId       String
  userId          String
  status          JobStatus @default(QUEUED)
  format          String
  resolution      String
  r2Key           String?
  durationSeconds Int?
  errorMessage    String?
  createdAt       DateTime  @default(now())
  completedAt     DateTime?
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WebhookEvent {
  id          String    @id @default(cuid())
  provider    String
  eventId     String
  payloadJson Json
  processedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@unique([provider, eventId])
  @@index([expiresAt])
}

model OutboxEvent {
  id            String    @id @default(cuid())
  aggregateId   String
  aggregateType String
  type          String
  payload       Json
  publishedAt   DateTime?
  attempts      Int       @default(0)
  lastError     String?
  createdAt     DateTime  @default(now())

  @@index([publishedAt, createdAt])
  @@index([aggregateType, aggregateId, createdAt])
}

model AiModelStats {
  key                    String    @id
  usageRequestCount      Int       @default(0)
  usageGeneratedImages   Int       @default(0)
  aiCreatorImageCount    Int       @default(4)
  lastUsedAt             DateTime?
  pricePerSecondOverride Json?
  active                 Boolean   @default(true)
  selected               Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([active])
  @@index([selected, active])
}

model ReasoningModel {
  id                            String   @id @default(cuid())
  key                           String   @unique
  provider                      String
  providerModelId               String
  displayName                   String
  contextWindowTokens           Int
  inputTokenPriceUsdPerMillion  Float    @default(0)
  outputTokenPriceUsdPerMillion Float    @default(0)
  reasoningEffort               String   @default("medium")
  excludeReasoning              Boolean  @default(true)
  promptTokensUsed              Int      @default(0)
  completionTokensUsed          Int      @default(0)
  reasoningTokensUsed           Int      @default(0)
  totalTokensUsed               Int      @default(0)
  requestCount                  Int      @default(0)
  estimatedCostUsd              Float    @default(0)
  selected                      Boolean  @default(false)
  active                        Boolean  @default(true)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt

  @@index([provider, active])
  @@index([selected, active])
}
